# =============================================================
# AutoDoc — Configuración de entorno
# Copia este fichero a .env y rellena con tus valores reales.
# NUNCA subas .env a control de versiones.
# =============================================================

# --- Conexión IMAP ---
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_TLS=true
IMAP_USER=despacho@ejemplo.com
IMAP_PASS=tu_app_password_aqui
# Para Gmail: habilita "Contraseñas de aplicación" en la cuenta de Google.
# Para Outlook: usa IMAP con contraseña de aplicación o OAuth.

# --- Scheduler ---
# Expresión cron: cada 5 minutos por defecto
CRON_SCHEDULE=*/5 * * * *
# Número de emails procesados en paralelo (evita saturar el servidor IMAP)
MAX_CONCURRENT_EMAILS=3

# --- Filtros de adjuntos ---
MAX_ATTACHMENT_SIZE_MB=25
ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png,image/heic,image/heif,image/jpg

# --- Umbrales de clasificación ---
# Si keywords dan confianza >= este valor, no se llama a Python
KEYWORD_CONFIDENCE_THRESHOLD=0.7
# Si Python OCR da confianza >= este valor, se clasifica; si no, va a revisión manual
OCR_CONFIDENCE_THRESHOLD=0.65

# --- Python (OCR fallback) ---
# Ruta al ejecutable Python (puede ser 'python', 'python3', o ruta absoluta)
PYTHON_PATH=python
# Ruta al ejecutable Tesseract OCR en Windows
# Descarga en: https://github.com/UB-Mannheim/tesseract/wiki
TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe
# Poner en 'false' para deshabilitar el bridge Python (solo keywords)
PYTHON_OCR_ENABLED=true

# --- Rutas de datos ---
DATA_DIR=./data
LOGS_DIR=./logs

# --- Entorno ---
NODE_ENV=development
LOG_LEVEL=info
