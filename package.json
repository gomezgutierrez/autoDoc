{
  "name": "autodoc",
  "version": "1.0.0",
  "description": "Sistema local de automatización documental para despacho de abogados",
  "main": "src/index.js",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "dry-run": "node src/index.js --dry-run",
    "test:pipeline": "node src/index.js --dry-run --single-pass"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "heic-convert": "^2.1.0",
    "imapflow": "^1.0.167",
    "mailparser": "^3.7.1",
    "node-cron": "^3.0.3",
    "p-limit": "^4.0.0",
    "pdf-lib": "^1.17.1",
    "sharp": "^0.33.4",
    "uuid": "^9.0.1",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {},
  "keywords": [
    "autodoc",
    "abogados",
    "imap",
    "pdf",
    "clasificacion",
    "expedientes"
